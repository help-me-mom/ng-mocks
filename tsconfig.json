{
  "extends": "./libs/ng-mocks/tsconfig.json",
  "compilerOptions": {
    "module": "ES2022",
    "moduleResolution": "bundler",
    "rootDir": ".",
    "target": "ES2015",
    "emitDecoratorMetadata": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "ng-mocks": ["./libs/ng-mocks/src/index.ts"]
    },
    "types": [
      "jasmine",
      "jest",
      "karma-coverage-istanbul-reporter",
      "karma-jasmine",
      "karma-junit-reporter",
      "karma-webpack",
      "node"
    ]
  },
  "files": ["libs/ng-mocks/src/index.ts", "empty.ts", "test.ts", "karma.conf.ts"],
  "exclude": ["e2e", "node_modules", "tests/issue-1596", "tests/issue-296", "tests/issue-736"],
  "include": [
    "libs/ng-mocks/src/lib/**/*.ts",
    "examples/**/*.ts",
    "tests/**/*.ts",
    "tests-failures/**/*.ts",
    "tests-performance/**/*.ts"
  ]
}
