{
  "name": "a22",
  "description": "Angular 22",
  "version": "0.0.0",
  "scripts": {
    "npm": "npm",
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "npm run test:jasmine && npm run test:jest",
    "test:debug": "npm run test:jasmine:debug",
    "test:jasmine": "ng test --ts-config ./tsconfig.json --progress=false --no-watch",
    "test:jasmine:debug": "npm run test:jasmine -- --watch --browsers Chrome",
    "test:jest": "jest --config jest.config.ts",
    "test:jest:debug": "jest -i --watch"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "22.0.0-next.3",
    "@angular/common": "22.0.0-next.3",
    "@angular/compiler": "22.0.0-next.3",
