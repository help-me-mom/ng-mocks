{
  "name": "ng-mocks",
  "private": true,
  "scripts": {
    "npm": "npm",
    "release": "export $(cat .env) && semantic-release",
    "build": "npm run clean && npm run build:webpack && npm run build:types && cp CHANGELOG.md dist/libs/ng-mocks && cp README.md dist/libs/ng-mocks && cp LICENSE dist/libs/ng-mocks && cp libs/ng-mocks/package.json dist/libs/ng-mocks/package.json && cp libs/ng-mocks/migrations.json dist/libs/ng-mocks/migrations.json && cp examples/main/test.spec.ts dist/libs/ng-mocks/example.spec.ts",
    "build:dev": "MODE=development npm run build",
    "build:webpack": "webpack",
    "build:types": "dts-bundle-generator --no-banner -o ./dist/libs/ng-mocks/index.d.ts --project ./libs/ng-mocks/tsconfig.build.cjs.json --no-check --export-referenced-types=true ./libs/ng-mocks/src/index.ts",
    "build:all": "npm run lint && npm run build && npm run test",
    "build:docs": "cd docs && CI=true npm run build",
    "clean": "rm -rf dist test-reports tmp",
    "test": "karma start",
    "test:debug": "npm run test:watch -- --browsers=Chrome --reporters=dots,kjhtml",
    "test:watch": "karma start --auto-watch --single-run=false",
    "e2e": "cd tests-e2e && npm run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier:repo": "prettier -u -w .",
    "prettier:check": "prettier -u -c .",
    "prettier:stage": "pretty-quick --staged",
    "ts:check": "tsc -p tsconfig.json --noEmit",
    "e2e:a": "npm run i:a && npm run e2e:a:fast",
    "e2e:a:fast": "npm run build && npm run clean:a && npm run s:a && npm run s:test:a && npm run test:a",
    "i:docs": "cd docs && npm install --no-audit",
    "i:tests-e2e": "cd tests-e2e && npm ci --no-audit",
    "start:docs": "cd docs && npm run start",
    "i:e2e": "npm run i:a17 && npm run i:a18 && npm run i:a19 && npm run i:a20 && npm run i:jasmine && npm run i:jest && npm run i:min && npm run i:nx",
    "i:a17": "cd e2e/a17 && npm install --no-audit",
    "i:a18": "cd e2e/a18 && npm install --no-audit",
    "i:a19": "cd e2e/a19 && npm install --no-audit",
    "i:a20": "cd e2e/a20 && npm install --no-audit",
    "i:jasmine": "cd e2e/jasmine && npm install --no-audit",
    "i:jest": "cd e2e/jest && npm install --no-audit",
    "i:min": "cd e2e/min && npm install --no-audit",
    "i:nx": "cd e2e/nx && npm install --no-audit",
    "i:ci:a17": "cd e2e/a17 && npm ci",
    "i:ci:a18": "cd e2e/a18 && npm ci",
    "i:ci:a19": "cd e2e/a19 && npm ci",
    "i:ci:a20": "cd e2e/a20 && npm ci --force",
    "i:ci:jasmine": "cd e2e/jasmine && npm ci",
    "i:ci:jest": "cd e2e/jest && npm ci",
    "i:ci:min": "cd e2e/min && npm ci",
    "i:ci:nx": "cd e2e/nx && npm ci",
    "s:e2e": "npm run s:a17 && npm run s:a18 && npm run s:a19 && npm run s:a20 && npm run s:jasmine && npm run s:jest && npm run s:min && npm run s:nx",
    "s:a17": "P=e2e/a17/node_modules/ng-mocks && rm -Rf $P && mkdir -p $P && cp -R dist/libs/ng-mocks/. $P",
    "s:a18": "P=e2e/a18/node_modules/ng-mocks && rm -Rf $P && mkdir -p $P && cp -R dist/libs/ng-mocks/. $P",
    "s:a19": "P=e2e/a19/node_modules/ng-mocks && rm -Rf $P && mkdir -p $P && cp -R dist/libs/ng-mocks/. $P",
    "s:a20": "P=e2e/a20/node_modules/ng-mocks && rm -Rf $P && mkdir -p $P && cp -R dist/libs/ng-mocks/. $P",
    "s:jasmine": "P=e2e/jasmine/node_modules/ng-mocks && rm -Rf $P && mkdir -p $P && cp -R dist/libs/ng-mocks/. $P",
    "s:jest": "P=e2e/jest/node_modules/ng-mocks && rm -Rf $P && mkdir -p $P && cp -R dist/libs/ng-mocks/. $P",
    "s:min": "P=e2e/min/node_modules/ng-mocks && rm -Rf $P && mkdir -p $P && cp -R dist/libs/ng-mocks/. $P",
    "s:nx": "P=e2e/nx/node_modules/ng-mocks && rm -Rf $P && mkdir -p $P && cp -R dist/libs/ng-mocks/. $P",
    "clean:e2e": "npm run clean:a17 && npm run clean:a18 && npm run clean:a19 && npm run clean:a20 && npm run clean:jasmine && npm run clean:jest && npm run clean:min && npm run clean:nx",
    "clean:a17": "rm -Rf e2e/a17/node_modules/ng-mocks && rm -Rf e2e/a17/test",
    "clean:a18": "rm -Rf e2e/a18/node_modules/ng-mocks && rm -Rf e2e/a18/test",
    "clean:a19": "rm -Rf e2e/a19/node_modules/ng-mocks && rm -Rf e2e/a19/test",
    "clean:a20": "rm -Rf e2e/a20/node_modules/ng-mocks && rm -Rf e2e/a20/test",
    "clean:jasmine": "rm -Rf e2e/jasmine/node_modules/ng-mocks",
    "clean:jest": "rm -Rf e2e/jest/node_modules/ng-mocks",
    "clean:min": "rm -Rf e2e/min/node_modules/ng-mocks",
    "clean:nx": "rm -Rf e2e/nx/node_modules/ng-mocks && rm -Rf e2e/nx/apps/a-nx/src/test",
    "s:test:e2e": "npm run s:test:a17 && npm run s:test:a18 && npm run s:test:a19 && npm run s:test:a20 && npm run s:test:nx",
    "s:test:a17": "P=e2e/a17/src/test && rm -Rf $P && mkdir -p $P && cp -R tests $P && cp -R examples $P",
    "s:test:a18": "P=e2e/a18/src/test && rm -Rf $P && mkdir -p $P && cp -R tests $P && cp -R examples $P",
    "s:test:a19": "P=e2e/a19/src/test && rm -Rf $P && mkdir -p $P && cp -R tests $P && cp -R examples $P",
    "s:test:a20": "P=e2e/a20/src/test && rm -Rf $P && mkdir -p $P && cp -R tests $P && cp -R examples $P",
    "s:test:jasmine": "node --version",
    "s:test:jest": "node --version",
    "s:test:min": "node --version",
    "s:test:nx": "P=e2e/nx/src/test && rm -Rf $P && mkdir -p $P && cp -R tests $P && cp -R examples $P",
    "s:app:e2e": "npm run s:app:a17 && npm run s:app:a18 && npm run s:app:a19 && npm run s:app:a20 && npm run s:app:jasmine && npm run s:app:jest && npm run s:app:min && npm run s:app:nx",
    "s:app:a17": "P=e2e/a17/src/app && rm -Rf $P && mkdir -p $P && cp -R tests-e2e/src/app/. $P",
    "s:app:a18": "P=e2e/a18/src/app && rm -Rf $P && mkdir -p $P && cp -R tests-e2e/src/app/. $P",
    "s:app:a19": "P=e2e/a19/src/app && rm -Rf $P && mkdir -p $P && cp -R tests-e2e/src/app/. $P",
    "s:app:a20": "P=e2e/a20/src/app && rm -Rf $P && mkdir -p $P && cp -R tests-e2e/src/app/. $P",
    "s:app:jasmine": "P=e2e/jasmine/src/app && rm -Rf $P && mkdir -p $P && cp -R tests-e2e/src/app/. $P",
    "s:app:jest": "P=e2e/jest/src/app && rm -Rf $P && mkdir -p $P && cp -R tests-e2e/src/app/. $P",
    "s:app:min": "P=e2e/min/src/app && rm -Rf $P && mkdir -p $P && cp -R tests-e2e/src/app/. $P",
    "s:app:nx": "P=e2e/nx/src/app && rm -Rf $P && mkdir -p $P && cp -R tests-e2e/src/app/. $P",
    "test:e2e": "npm run test:a17 && npm run test:a18 && npm run test:a19 && npm run test:a20 && npm run test:jasmine && npm run test:jest && npm run test:min && npm run test:nx",
    "test:a17": "cd e2e/a17 && npm run test:jasmine && npm run test:jest",
    "test:a18": "cd e2e/a18 && npm run test:jasmine && npm run test:jest",
    "test:a19": "cd e2e/a19 && npm run test:jasmine && npm run test:jest",
    "test:a20": "cd e2e/a20 && npm run test:jasmine && npm run test:jest",
    "test:jasmine": "cd e2e/jasmine && npm run test:jasmine",
    "test:jest": "cd e2e/jest && npm run test:jest",
    "test:min": "cd e2e/min && npm run test:jasmine",
    "test:nx": "cd e2e/nx && npm run test",
    "lib:e2e": "npm run lib:a17 && npm run lib:a18 && npm run lib:a19 && npm run lib:a20 && npm run lib:jasmine && npm run lib:jest && npm run lib:min && npm run lib:nx",
    "lib:a17": "cd e2e/a17 && npm run build lib",
    "lib:a18": "cd e2e/a18 && npm run build lib",
    "lib:a19": "cd e2e/a19 && npm run build lib",
    "lib:a20": "cd e2e/a20 && npm run build lib",
    "lib:jasmine": "cd e2e/jasmine && npm run build lib",
    "lib:jest": "cd e2e/jest && npm run build lib",
    "lib:min": "cd e2e/min && npm run build lib",
    "lib:nx": "cd e2e/nx && npm run build lib",
    "prepare": "husky"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "21.3.0",
    "@angular-eslint/eslint-plugin-template": "21.3.0",
    "@angular-eslint/template-parser": "21.3.0",
    "@angular/animations": "20.3.17",
